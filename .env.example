# ── AgentOS environment ──────────────────────────────────────────────
# Leave provider keys empty to run everything against the MockModelAdapter.
# Set AGENTOS_FORCE_MOCK=true to force mock mode even when keys are present.

AGENTOS_FORCE_MOCK=true

# Gemini 3 Flash
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-3-flash

# Kimi K2.6 (Moonshot)
KIMI_API_KEY=
KIMI_BASE_URL=https://api.moonshot.ai/v1
KIMI_MODEL=kimi-k2.6

# DeepSeek V4 Pro
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-v4-pro

# Evaluation store: "memory" (JSON file) or "prisma"
AGENTOS_EVAL_STORE=memory
AGENTOS_EVAL_FILE=.agentos/evaluations.json

# Prisma / Postgres (only needed when AGENTOS_EVAL_STORE=prisma)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agentos?schema=public

# Dashboard
DASHBOARD_PORT=4317
